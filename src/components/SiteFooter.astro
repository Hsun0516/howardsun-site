---
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-900 px-6 py-10">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 text-sm text-zinc-500 md:flex-row md:items-center md:justify-between">
    <p>© {year} Howard Sun. Research, engineering, and technical notes.</p>
    <div class="flex gap-5">
      <a href="https://github.com/Hsun0516" class="transition hover:text-cyan-300">GitHub</a>
      <a href={`${import.meta.env.BASE_URL}projects`} class="transition hover:text-cyan-300">Projects</a>
      <a href={`${import.meta.env.BASE_URL}blog`} class="transition hover:text-cyan-300">Blog</a>
    </div>
  </div>
</footer>
