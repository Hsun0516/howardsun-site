---
interface Props {
  title: string;
  category: string;
  description: string;
  href?: string;
}

const { title, category, description, href } = Astro.props;
---

<article class="border-t border-zinc-800 py-5">
  <p class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">{category}</p>
  <h3 class="mt-2 text-lg font-semibold text-zinc-100">
    {href ? <a href={href} class="transition hover:text-cyan-300">{title}</a> : title}
  </h3>
  <p class="mt-2 leading-7 text-zinc-400">{description}</p>
</article>
