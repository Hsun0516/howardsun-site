---
interface Props {
  title: string;
  description: string;
  tags: string[];
  status?: string;
  href?: string;
}

const { title, description, tags, status, href } = Astro.props;
---

<article class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-5 transition hover:border-zinc-700">
  <a href={href ?? "#"} class:list={["block", !href && "pointer-events-none"]}>
    <div class="flex items-start justify-between gap-4">
      <h3 class="text-lg font-semibold text-zinc-100">{title}</h3>
      {status && <span class="shrink-0 font-mono text-xs text-cyan-300">{status}</span>}
    </div>
    <p class="mt-3 leading-7 text-zinc-400">{description}</p>
    <div class="mt-5 flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <span class="rounded-md border border-zinc-800 px-2.5 py-1 font-mono text-xs text-zinc-400">
            {tag}
          </span>
        ))
      }
    </div>
  </a>
</article>
