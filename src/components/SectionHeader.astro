---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="font-mono text-xs uppercase tracking-[0.24em] text-cyan-300">{eyebrow}</p>}
  <h2 class="mt-3 text-2xl font-semibold tracking-tight text-zinc-100 md:text-3xl">{title}</h2>
  {description && <p class="mt-4 leading-7 text-zinc-400">{description}</p>}
</div>
