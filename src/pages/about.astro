---
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
---

<Layout title="About">
  <section class="mx-auto max-w-4xl px-6 py-20">
    <SectionHeader
      eyebrow="About"
      title="Mathematics, machine learning, and systems engineering."
      description="I am a mathematics student building depth in AI engineering, ML systems, reinforcement learning, optimization, and Unity/C# game systems."
    />
    <div class="mt-10 space-y-6 leading-8 text-zinc-400">
      <p>
        This site collects project writeups, research notes, and technical essays. The focus is on
        clear reasoning, implementation details, and durable engineering choices.
      </p>
      <p>
        Current interests include gradient boosting, reinforcement learning environments, simulation,
        optimization, technical writing, and modular gameplay architecture.
      </p>
    </div>
  </section>
</Layout>
